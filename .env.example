OPENAI_API_KEY=your_openai_api_key_here
TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
WINDOWS_AGENT_URL=http://127.0.0.1:8765/type

# App-level token for /transcribe protection (recommended for remote use)
VOICE_INPUT_TOKEN=replace_with_a_long_random_secret

# ngrok basic auth (recommended for remote use)
NGROK_BASIC_AUTH=your_user:your_strong_password
# Alternative split form:
# NGROK_BASIC_AUTH_USER=your_user
# NGROK_BASIC_AUTH_PASS=your_strong_password
